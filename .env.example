# GEMINI_API_KEY / VITE_GEMINI_API_KEY: Required for Gemini AI API calls.
# Serenity runs as a pure frontend SPA client-side.
# For local development or deployment environments, please set:
VITE_GEMINI_API_KEY="AQ.Ab8RN6JeNBQJ5vtJ2Buo9tes-MM2_-ot02LIB1mWO7ktt9UGNg"
GEMINI_API_KEY="AQ.Ab8RN6JeNBQJ5vtJ2Buo9tes-MM2_-ot02LIB1mWO7ktt9UGNg"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
